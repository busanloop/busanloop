---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "busanloop" } = Astro.props;
const pageTitle = title === "busanloop" ? title : `${title} — busanloop`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta
      name="description"
      content="Archiving the loop between people, startups, and the city of Busan."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="container">
      <slot />
      <footer>&copy; busanloop</footer>
    </div>
  </body>
</html>
